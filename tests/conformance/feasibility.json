{
  "suite": "feasibility",
  "description": "Verification feasibility checking — is the sample size sufficient?",
  "method": "Wilson score criterion: n / (n + z^2) >= target; n_min = ceil(target * z^2 / (1 - target))",
  "tolerance": 0,
  "cases": [
    {
      "name": "fair_coin_n5_95pct",
      "inputs": {
        "target_proportion": 0.5,
        "sample_size": 5,
        "confidence": 0.95
      },
      "expected": {
        "feasible": true,
        "minimum_samples": 3,
        "criterion": "wilson_score_one_sided_lower_bound"
      }
    },
    {
      "name": "high_rate_n30_95pct",
      "inputs": {
        "target_proportion": 0.9,
        "sample_size": 30,
        "confidence": 0.95
      },
      "expected": {
        "feasible": true,
        "minimum_samples": 25,
        "criterion": "wilson_score_one_sided_lower_bound"
      }
    },
    {
      "name": "high_rate_n20_95pct_undersized",
      "inputs": {
        "target_proportion": 0.9,
        "sample_size": 20,
        "confidence": 0.95
      },
      "expected": {
        "feasible": false,
        "minimum_samples": 25,
        "criterion": "wilson_score_one_sided_lower_bound"
      }
    },
    {
      "name": "very_high_rate_n55_95pct",
      "inputs": {
        "target_proportion": 0.95,
        "sample_size": 55,
        "confidence": 0.95
      },
      "expected": {
        "feasible": true,
        "minimum_samples": 52,
        "criterion": "wilson_score_one_sided_lower_bound"
      }
    },
    {
      "name": "near_perfect_n100_95pct_undersized",
      "inputs": {
        "target_proportion": 0.9999,
        "sample_size": 100,
        "confidence": 0.95
      },
      "expected": {
        "feasible": false,
        "minimum_samples": 27053,
        "criterion": "wilson_score_one_sided_lower_bound"
      }
    },
    {
      "name": "high_rate_n30_99pct",
      "inputs": {
        "target_proportion": 0.9,
        "sample_size": 30,
        "confidence": 0.99
      },
      "expected": {
        "feasible": false,
        "minimum_samples": 49,
        "criterion": "wilson_score_one_sided_lower_bound"
      }
    },
    {
      "name": "high_rate_n60_99pct",
      "inputs": {
        "target_proportion": 0.9,
        "sample_size": 60,
        "confidence": 0.99
      },
      "expected": {
        "feasible": true,
        "minimum_samples": 49,
        "criterion": "wilson_score_one_sided_lower_bound"
      }
    }
  ]
}
