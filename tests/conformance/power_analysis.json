{
  "suite": "power_analysis",
  "description": "Sample size calculation via power analysis for one-sided binomial proportion tests",
  "method": "Standard power formula: n = ((z_alpha * sigma_0 + z_beta * sigma_1) / delta)^2",
  "tolerance": 1e-10,
  "cases": [
    {
      "name": "typical_llm_95pct_5pct_effect_80power",
      "inputs": {
        "baseline_rate": 0.95,
        "min_detectable_effect": 0.05,
        "confidence": 0.95,
        "power": 0.8
      },
      "expected": {
        "required_samples": 150,
        "achieved_power": 0.801302554374439
      }
    },
    {
      "name": "high_baseline_99pct_2pct_effect_80power",
      "inputs": {
        "baseline_rate": 0.99,
        "min_detectable_effect": 0.02,
        "confidence": 0.95,
        "power": 0.8
      },
      "expected": {
        "required_samples": 236,
        "achieved_power": 0.800024834831698
      }
    },
    {
      "name": "fair_coin_50pct_10pct_effect_80power",
      "inputs": {
        "baseline_rate": 0.5,
        "min_detectable_effect": 0.1,
        "confidence": 0.95,
        "power": 0.8
      },
      "expected": {
        "required_samples": 153,
        "achieved_power": 0.801252783463783
      }
    },
    {
      "name": "high_power_95pct_5pct_effect_95power",
      "inputs": {
        "baseline_rate": 0.95,
        "min_detectable_effect": 0.05,
        "confidence": 0.95,
        "power": 0.95
      },
      "expected": {
        "required_samples": 291,
        "achieved_power": 0.950340273106342
      }
    },
    {
      "name": "small_effect_95pct_1pct_effect_80power",
      "inputs": {
        "baseline_rate": 0.95,
        "min_detectable_effect": 0.01,
        "confidence": 0.95,
        "power": 0.8
      },
      "expected": {
        "required_samples": 3118,
        "achieved_power": 0.800034230683624
      }
    },
    {
      "name": "high_confidence_95pct_5pct_effect_99conf",
      "inputs": {
        "baseline_rate": 0.95,
        "min_detectable_effect": 0.05,
        "confidence": 0.99,
        "power": 0.8
      },
      "expected": {
        "required_samples": 231,
        "achieved_power": 0.800402968951298
      }
    }
  ]
}
